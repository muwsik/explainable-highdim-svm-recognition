{
    // Используйте IntelliSense, чтобы узнать о возможных атрибутах.
    // Наведите указатель мыши, чтобы просмотреть описания существующих атрибутов.
    "version": "0.2.0",
    "configurations": [        
        {
            "name": "Debug current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
        },
        {
            "name": "Debug CV experiment",
            "type": "debugpy",
            "request": "launch",
            "program": "combiningSubspaces/CV_experiment.py",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--data",       "datasets\\darwin\\darwin.npz",
                "--C",          "0.1",
                "--model",      "Comb-LSVC-l1",
                "--splits",     "15",
                "--output",     "temp.xlsx"
            ]
        },
        {
            "name": "Debug split experiment",
            "type": "debugpy",
            "request": "launch",
            "program": "combiningSubspaces/split_experiment.py",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                 "--train",     "D:\\Projects\\explainable-highdim-svm-recognition\\datasets\\gisette\\gisette_scale_tr.npz",
                "--test",       "D:\\Projects\\explainable-highdim-svm-recognition\\datasets\\gisette\\gisette_scale_t.npz",
                "--C",          "0.1",
                "--model",      "Comb-LSVC-l1",
                "--splits",     "2",
                "--output",     "temp.xlsx"
            ]
        }
    ]
}
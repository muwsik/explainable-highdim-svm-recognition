            "program": "${file}",
             "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
        },
        {
            "name": "Debug experiment.py",
            "type": "debugpy",
            "request": "launch",
            "program": "combiningSubspaces/experiment.py",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--train", "D:\\datasets\\train-10k-10.npz",
                "--test", "D:\\datasets\\test-10k-10.npz",
                "--C", "1",
                // "--model", "LinearSVC",
                // "--penalty", "l1", 
                "--model", "SVC",
                "--kernel", "linear",
                // "--model", "CombLinSVM-LSVC",
                // "--splits", "1",
                "--output", "temp.xlsx"
            ]
        }
    ]
}
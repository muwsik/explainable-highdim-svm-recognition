                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--train", "D:\\datasets\\mc-train-10k-f5000-i5000-r0-l0.npz",
                "--test", "D:\\datasets\\mc-test-10k-f5000-i5000-r0-l0.npz",
                "--C", "0.001",
                // "--model", "LinearSVC",
                // "--penalty", "l1", 
                // "--model", "SVC",
                // "--kernel", "linear",
                "--model", "CombLinSVM-LSVC",
